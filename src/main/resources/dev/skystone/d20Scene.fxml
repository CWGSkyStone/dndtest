<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.skystone.D20Controller"
      prefWidth="720"
      prefHeight="1080"
      spacing="20"
      stylesheets="@D20style.css">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- TITLE -->
    <Label text="D20 ROLLER"
           style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: bold;" />

    <!-- MODIFIERS -->
    <VBox spacing="10">
        <Label text="Modifiers"
               style="-fx-text-fill: #cccccc; -fx-font-size: 18px;" />

        <ToggleButton fx:id="advantageToggle" text="Advantage"/>
        <ToggleButton fx:id="disadvantageToggle" text="Disadvantage"/>
        <ToggleButton fx:id="inspirationToggle" text="Inspiration Prompt"/>
    </VBox>

    <!-- ATTACK TYPE -->
    <VBox spacing="10">
        <Label text="Attack Type"
               style="-fx-text-fill: #cccccc; -fx-font-size: 18px;" />

        <RadioButton fx:id="meleeRadio"
                     text="Melee"
                     toggleGroup="$attackTypeGroup"
                     selected="true"/>

        <RadioButton fx:id="rangedRadio"
                     text="Ranged"
                     toggleGroup="$attackTypeGroup"/>
    </VBox>

    <!-- CRIT SETTINGS -->
    <VBox spacing="10">
        <Label text="Critical Settings"
               style="-fx-text-fill: #cccccc; -fx-font-size: 18px;" />

        <HBox spacing="10">
            <Label text="Crit Success ≥" style="-fx-text-fill: white;" />
            <TextField fx:id="critSuccessField" prefWidth="80"/>
        </HBox>

        <HBox spacing="10">
            <Label text="Crit Failure ≤" style="-fx-text-fill: white;" />
            <TextField fx:id="critFailField" prefWidth="80"/>
        </HBox>
    </VBox>

    <!-- ROLL COUNT -->
    <HBox spacing="10">
        <Label text="Roll Count" style="-fx-text-fill: white;" />
        <TextField fx:id="rollCountField" prefWidth="80" text="1"/>
    </HBox>

    <!-- BUTTON -->
    <Button text="ROLL"
            onAction="#onRollClicked"
            prefHeight="70"/>

    <!-- INLINE PROMPT -->
    <VBox fx:id="inspirationBox"
          visible="false"
          managed="false"
          spacing="10"
          style="-fx-background-color: #2a2a2a; -fx-padding: 15;">

        <Label fx:id="inspirationLabel"/>

        <HBox spacing="10">
            <Button text="Use Inspiration" onAction="#onUseInspiration"/>
            <Button text="Keep Roll" onAction="#onKeepRoll"/>
        </HBox>
    </VBox>

    <!-- RESULTS -->
    <TextArea fx:id="resultArea"
              VBox.vgrow="ALWAYS"
              editable="false"
              wrapText="true"/>

</VBox>